    t = list.last;
    while (t)
    {
        printf("%d %s\n", t->emp.id, t->emp.name);
        t = t->prev;
    }
}

DoubleList deleteDNodeEnd(DoubleList list)
{
    if (list.first)
    {
        DNode* t = list.last;
        if (t == list.first)
        {
            free(t->emp.name);
            free(t);
            list.first = list.last = NULL;
        }
        else
        {
            list.last = t->prev;
            list.last->next = NULL;
            free(t->emp.name);
            free(t);
        }
    }
    return list;
}

